# ---------------------------------------------------------------
# Production environment — used by docker-compose.prod.yml
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.
# In CI/CD, inject these as secrets instead of a file.
# ---------------------------------------------------------------

PORT=
NODE_ENV=
LOG_LEVEL=

JWT_SECRET=

# Full Neon Cloud connection string (from Neon Console → Connection Details).
# Keep sslmode=require and channel_binding=require for security.
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?channel_binding=require&sslmode=require

# NEON_LOCAL_ENDPOINT must NOT be set in production.
# Leaving it unset tells db.js to use the standard Neon Cloud path.
