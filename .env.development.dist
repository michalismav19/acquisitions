# ---------------------------------------------------------------
# Development environment — used by docker-compose.dev.yml
# Copy this file to .env.development and fill in real values.
# NEVER commit .env.development to version control.
# ---------------------------------------------------------------

PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Neon Local proxy connection string.
# "neon-local" is the Docker Compose service name — do not change.
DATABASE_URL=postgres://neon:npg@neon-local:5432/neondb

# Tells db.js to route @neondatabase/serverless HTTP queries
# to the Neon Local proxy instead of Neon Cloud.
NEON_LOCAL_ENDPOINT=http://neon-local:5432/sql

# --- Neon Local container credentials ---
# Find these in https://console.neon.tech → Project Settings → General
NEON_API_KEY=your_neon_api_key_here
NEON_PROJECT_ID=your_neon_project_id_here
# The branch Neon Local will fork a new ephemeral branch from on startup.
# Use your main / staging branch ID.
PARENT_BRANCH_ID=your_parent_branch_id_here
